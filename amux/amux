#!/usr/bin/env bash

AMUX_DIR="$(dirname "$(realpath "$0")")"
GLOBAL_DIR="$AMUX_DIR/sessions"
LOCAL_DIR="$AMUX_DIR/sessions.local"

resolve_session() {
  local name="$1"
  [[ -f "$LOCAL_DIR/$name.sh" ]]  && echo "$LOCAL_DIR/$name.sh"  && return
  [[ -f "$GLOBAL_DIR/$name.sh" ]] && echo "$GLOBAL_DIR/$name.sh" && return
}

list_templates() {
  for dir in "$LOCAL_DIR" "$GLOBAL_DIR"; do
    [[ -d "$dir" ]] || continue
    for f in "$dir"/_*.sh; do
      [[ -f "$f" ]] || continue
      base=$(basename "$f" .sh)
      echo "${base#_}"
    done
  done | sort -u
}

fzf_pick() {
  local prompt="$1"; shift
  local suggestions="$1"
  local result fzf_exit query selected
  result=$(echo "$suggestions" | fzf --prompt="$prompt: " --print-query --height=15 --no-info)
  fzf_exit=$?
  [[ $fzf_exit -eq 130 ]] && return 1
  query=$(echo "$result" | head -1)
  selected=$(echo "$result" | sed -n '2p')
  echo "${selected:-$query}"
}

case "$1" in
  new)
    TEMPLATE=$(list_templates | fzf --prompt="template: " --height=10 --no-info)
    [[ -z "$TEMPLATE" ]] && exit 0
    script=$(resolve_session "_$TEMPLATE")
    SUGGESTIONS=$(
      [[ -n "$script" ]] && source "$script" 2>/dev/null
      declare -f suggest > /dev/null 2>&1 && suggest 2>/dev/null
    )
    NAME=$(fzf_pick "$TEMPLATE" "$SUGGESTIONS") || exit 0
    [[ -z "$NAME" ]] && exit 0
    echo "→ $TEMPLATE: $NAME"
    bash "$script" "$NAME"
    ;;
  task)
    script=$(resolve_session _task)
    [[ -z "$script" ]] && echo "no _task.sh template found" && exit 1
    bash "$script" "$2"
    ;;
  dev)
    script=$(resolve_session _dev)
    [[ -z "$script" ]] && echo "no _dev.sh template found" && exit 1
    bash "$script" "$2"
    ;;
  master)
    script=$(resolve_session _dev)
    [[ -z "$script" ]] && echo "no _dev.sh template found" && exit 1
    bash "$script" master
    ;;
  rm)
    TASK="$2"
    [[ -z "$TASK" ]] && echo "usage: amux rm <task>" && exit 1
    template=$(tmux showenv -t "$TASK" AMUX_TEMPLATE 2>/dev/null | cut -d= -f2)
    script=$(resolve_session "$template")
    if [[ -n "$script" ]]; then
      source "$script"
      unload "$TASK"
    else
      tmux kill-session -t "$TASK" 2>/dev/null
    fi
    ;;
  "")
    if tmux ls >/dev/null 2>/dev/null; then
      [[ -n "$TMUX" ]] && tmux choose-session || tmux attach
    else
      tmux
    fi
    ;;
  *)
    script=$(resolve_session "$1")
    if [[ -n "$script" ]]; then
      bash "$script"
    else
      tmux new-session -A -s "$1"
    fi
    ;;
esac
